    {
      "name": "TC03 - Get random joke and save id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/random_joke",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "random_joke"
          ]
        },
        "description": "Checks the legacy random joke endpoint and stores id for the next request."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set(\"expectedStatus\", 200);",
              "pm.test(\"Status code is \" + pm.environment.get(\"expectedStatus\"), () => {",
              "  pm.response.to.have.status(Number(pm.environment.get(\"expectedStatus\")));",
              "});",
              "",
              "pm.test(\"Response time is acceptable\", () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(Number(pm.collectionVariables.get(\"maxResponseMs\")));",
              "});",
              "",
              "pm.test(\"Response has JSON content type\", () => {",
              "  pm.response.to.have.header(\"Content-Type\");",
              "  pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "const expectedTypes = JSON.parse(pm.collectionVariables.get(\"expectedTypes\"));",
              "const jokeSchema = {",
              "  type: \"object\",",
              "  required: [\"type\", \"setup\", \"punchline\", \"id\"],",
              "  properties: {",
              "    type: { type: \"string\", enum: expectedTypes },",
              "    setup: { type: \"string\", minLength: 1 },",
              "    punchline: { type: \"string\", minLength: 1 },",
              "    id: { type: \"number\" }",
              "  }",
              "};",
              "",
              "pm.test(\"Response matches joke schema\", () => {",
              "  const joke = pm.response.json();",
              "  pm.expect(joke).to.have.jsonSchema(jokeSchema);",
              "  pm.expect(joke.setup.trim()).to.not.eql(\"\");",
              "  pm.expect(joke.punchline.trim()).to.not.eql(\"\");",
              "});",
              "",
              "pm.test(\"Joke id is saved for follow-up request\", () => {",
              "  const joke = pm.response.json();",
              "  pm.collectionVariables.set(\"saved_joke_id\", joke.id);",
              "  pm.collectionVariables.set(\"saved_joke_setup\", joke.setup);",
              "  pm.collectionVariables.set(\"saved_joke_punchline\", joke.punchline);",
              "  pm.collectionVariables.set(\"saved_joke_type\", joke.type);",
              "  pm.expect(joke.id).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
