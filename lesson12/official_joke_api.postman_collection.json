  "item": [
    {
      "name": "TC01 - Ping returns pong",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/ping",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ping"
          ]
        },
        "description": "Checks that the local API process is alive."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response body is pong\", () => {",
              "  pm.expect(pm.response.text()).to.eql(\"pong\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC02 - Get random joke",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/random_joke",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "random_joke"
          ]
        },
        "description": "Checks the legacy random joke endpoint."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains a valid joke object\", () => {",
              "  const joke = pm.response.json();",
              "  pm.expect(joke).to.be.an(\"object\");",
              "  pm.expect(joke).to.include.keys([\"type\", \"setup\", \"punchline\", \"id\"]);",
              "  pm.expect(joke.type).to.be.a(\"string\");",
              "  pm.expect(joke.setup).to.be.a(\"string\");",
              "  pm.expect(joke.punchline).to.be.a(\"string\");",
              "  pm.expect(joke.id).to.be.a(\"number\");",
              "});"
            ]
          }
        }
      ]
    },
