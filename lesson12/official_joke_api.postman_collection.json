    {
      "name": "TC04 - Get ten random jokes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/random_ten",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "random_ten"
          ]
        },
        "description": "Checks that the legacy ten-random endpoint returns 10 unique jokes."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response returns 10 valid jokes\", () => {",
              "  const jokes = pm.response.json();",
              "  pm.expect(jokes).to.be.an(\"array\").with.lengthOf(10);",
              "  const ids = jokes.map(joke => joke.id);",
              "  pm.expect(new Set(ids).size).to.eql(jokes.length);",
              "  jokes.forEach(joke => {",
              "    pm.expect(joke).to.include.keys([\"type\", \"setup\", \"punchline\", \"id\"]);",
              "    pm.expect(joke.id).to.be.a(\"number\");",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
