{
    "include": ["test/**/*.ts", "wdio.conf.ts"],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022", "DOM"],
        "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework"],
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true
    }
}
