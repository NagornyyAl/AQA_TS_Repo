{
    "name": "lesson17-hotline-webdriver-io",
    "version": "1.0.0",
    "description": "Hotline.ua Page Object tests with WebDriverIO",
    "license": "ISC",
    "author": "",
    "type": "module",
    "scripts": {
        "test": "wdio run ./wdio.conf.ts",
        "check": "tsc --noEmit",
        "lint": "eslint \"test/**/*.ts\" \"wdio.conf.ts\"",
        "lint:fix": "eslint \"test/**/*.ts\" \"wdio.conf.ts\" --fix",
        "format": "prettier --write \"test/**/*.ts\" \"wdio.conf.ts\" \"*.json\" \"*.md\""
    },
    "devDependencies": {
        "@eslint/js": "^10.0.0",
        "@stylistic/eslint-plugin": "^5.0.0",
        "@types/chai": "^5.0.0",
        "@types/mocha": "^10.0.0",
        "@types/node": "^22.0.0",
        "@wdio/cli": "^9.0.0",
        "@wdio/globals": "^9.0.0",
        "@wdio/local-runner": "^9.0.0",
        "@wdio/mocha-framework": "^9.0.0",
        "@wdio/spec-reporter": "^9.0.0",
        "@wdio/types": "^9.0.0",
        "chai": "^5.0.0",
        "eslint": "^10.0.0",
        "eslint-plugin-unicorn": "^68.0.0",
        "globals": "^16.0.0",
        "prettier": "^3.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0",
        "webdriverio": "^9.0.0"
    }
}
