{
  "consumer": {
    "name": "PetstoreOrderConsumer"
  },
  "interactions": [
    {
      "description": "a request to place a store order",
      "providerStates": [
        {
          "name": "the Petstore accepts a purchase order"
        }
      ],
      "request": {
        "body": {
          "complete": false,
          "id": 10,
          "petId": 198772,
          "quantity": 2,
          "shipDate": "2026-06-14T19:30:00.000Z",
          "status": "placed"
        },
        "headers": {
          "Accept": "application/json",
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/v2/store/order"
      },
      "response": {
        "body": {
          "complete": false,
          "id": 10,
          "petId": 198772,
          "quantity": 2,
          "shipDate": "2026-06-14T19:30:00.000Z",
          "status": "placed"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
