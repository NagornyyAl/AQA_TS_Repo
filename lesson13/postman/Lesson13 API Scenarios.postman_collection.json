    "item": [
        {
            "name": "Cat API Integration Flow",
            "description": "Sequential integration flow: breeds -> images -> votes -> favourites -> cleanup.",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "if (!pm.variables.get('cat_api_key')) {",
                            "    throw new Error('Set cat_api_key in Postman environment or collection variables before running Cat API flow.');",
                            "}"
                        ]
                    }
                }
            ],
            "item": [
                {
                    "name": "01 - Search breed and validate breed contract",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.collectionVariables.set('sub_id', 'lesson13-postman-' + Date.now());",
                                    "['breed_id', 'breed_name', 'breed_origin', 'breed_reference_image_id', 'breed_payload', 'image_id', 'image_url', 'vote_id', 'favourite_id'].forEach((key) => pm.collectionVariables.unset(key));"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "function expectBreedContract(breed) {",
                                    "    pm.expect(breed.id).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.name).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.temperament).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.origin).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.country_codes).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.country_code).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.description).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.life_span).to.match(/^\\d+\\s-\\s\\d+$/);",
                                    "    pm.expect(breed.reference_image_id).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.weight.imperial).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.weight.metric).to.be.a('string').and.not.empty;",
                                    "    ['adaptability', 'affection_level', 'child_friendly', 'dog_friendly', 'energy_level', 'grooming', 'health_issues', 'intelligence', 'shedding_level', 'social_needs', 'stranger_friendly', 'vocalisation'].forEach((field) => {",
                                    "        pm.expect(breed[field], field).to.be.a('number').and.within(1, 5);",
                                    "    });",
                                    "    ['indoor', 'experimental', 'hairless', 'natural', 'rare', 'rex', 'suppressed_tail', 'short_legs', 'hypoallergenic'].forEach((field) => {",
                                    "        pm.expect(breed[field], field).to.be.a('number').and.within(0, 1);",
                                    "    });",
                                    "}",
                                    "",
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const breeds = pm.response.json();",
                                    "const selectedBreed = breeds.find((breed) => breed.id === 'sibe') || breeds[0];",
                                    "",
                                    "pm.test('Breed search returns rich breed data', function () {",
                                    "    pm.expect(breeds).to.be.an('array').and.not.empty;",
                                    "    expectBreedContract(selectedBreed);",
                                    "    pm.expect(selectedBreed.image).to.be.an('object');",
                                    "    pm.expect(selectedBreed.image.id).to.eql(selectedBreed.reference_image_id);",
                                    "    pm.expect(selectedBreed.image.url).to.match(/^https:\\/\\//);",
                                    "    pm.expect(selectedBreed.image.width).to.be.a('number').and.greaterThan(0);",
                                    "    pm.expect(selectedBreed.image.height).to.be.a('number').and.greaterThan(0);",
                                    "});",
                                    "",
                                    "pm.collectionVariables.set('breed_id', selectedBreed.id);",
                                    "pm.collectionVariables.set('breed_name', selectedBreed.name);",
                                    "pm.collectionVariables.set('breed_origin', selectedBreed.origin);",
                                    "pm.collectionVariables.set('breed_reference_image_id', selectedBreed.reference_image_id);",
                                    "pm.collectionVariables.set('breed_payload', JSON.stringify(selectedBreed));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "x-api-key",
                                "value": "{{cat_api_key}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{cat_base_url}}/breeds/search?q={{breed_query}}&attach_image=1"
                    },
                    "response": []
                },
                {
                    "name": "02 - Get selected breed by id and compare fields",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "function expectBreedContract(breed) {",
                                    "    pm.expect(breed.id).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.name).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.temperament).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.origin).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.country_codes).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.country_code).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.description).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.life_span).to.match(/^\\d+\\s-\\s\\d+$/);",
                                    "    pm.expect(breed.reference_image_id).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.weight.imperial).to.be.a('string').and.not.empty;",
                                    "    pm.expect(breed.weight.metric).to.be.a('string').and.not.empty;",
                                    "}",
                                    "",
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const expectedBreed = JSON.parse(pm.collectionVariables.get('breed_payload'));",
                                    "const actualBreed = pm.response.json();",
                                    "",
                                    "pm.test('Breed details preserve key fields from breed search', function () {",
                                    "    expectBreedContract(actualBreed);",
                                    "    pm.expect(actualBreed.id).to.eql(expectedBreed.id);",
                                    "    pm.expect(actualBreed.name).to.eql(expectedBreed.name);",
                                    "    pm.expect(actualBreed.temperament).to.eql(expectedBreed.temperament);",
                                    "    pm.expect(actualBreed.origin).to.eql(expectedBreed.origin);",
                                    "    pm.expect(actualBreed.description).to.eql(expectedBreed.description);",
                                    "    pm.expect(actualBreed.life_span).to.eql(expectedBreed.life_span);",
                                    "    pm.expect(actualBreed.reference_image_id).to.eql(expectedBreed.reference_image_id);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "x-api-key",
                                "value": "{{cat_api_key}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{cat_base_url}}/breeds/{{breed_id}}"
                    },
                    "response": []
                },
                {
                    "name": "03 - Search image for selected breed and validate embedded breed",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const expectedBreed = JSON.parse(pm.collectionVariables.get('breed_payload'));",
                                    "const images = pm.response.json();",
                                    "const image = images[0];",
                                    "const imageBreed = image && image.breeds.find((breed) => breed.id === expectedBreed.id);",
                                    "",
                                    "pm.test('Image response contains real image and full selected breed object', function () {",
                                    "    pm.expect(images).to.be.an('array').and.not.empty;",
                                    "    pm.expect(image.id).to.be.a('string').and.not.empty;",
                                    "    pm.expect(image.url).to.match(/^https:\\/\\//);",
                                    "    pm.expect(image.width).to.be.a('number').and.greaterThan(0);",
                                    "    pm.expect(image.height).to.be.a('number').and.greaterThan(0);",
                                    "    pm.expect(imageBreed).to.be.an('object');",
                                    "    pm.expect(imageBreed.name).to.eql(expectedBreed.name);",
                                    "    pm.expect(imageBreed.origin).to.eql(expectedBreed.origin);",
                                    "    pm.expect(imageBreed.temperament).to.eql(expectedBreed.temperament);",
                                    "    pm.expect(imageBreed.description).to.eql(expectedBreed.description);",
                                    "    pm.expect(imageBreed.reference_image_id).to.eql(expectedBreed.reference_image_id);",
                                    "});",
                                    "",
                                    "pm.collectionVariables.set('image_id', image.id);",
                                    "pm.collectionVariables.set('image_url', image.url);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "x-api-key",
                                "value": "{{cat_api_key}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{cat_base_url}}/images/search?breed_ids={{breed_id}}&has_breeds=true&limit=1"
                    },
                    "response": []
                },
                {
                    "name": "04 - Create vote for image",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "const vote = pm.response.json();",
                                    "pm.collectionVariables.set('vote_id', String(vote.id));",
                                    "",
                                    "pm.test('Vote links to selected image and sub_id', function () {",
                                    "    pm.expect(vote.id).to.be.a('number');",
                                    "    pm.expect(vote.image_id).to.eql(pm.collectionVariables.get('image_id'));",
                                    "    pm.expect(vote.sub_id).to.eql(pm.collectionVariables.get('sub_id'));",
                                    "    pm.expect(vote.value).to.eql(1);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
