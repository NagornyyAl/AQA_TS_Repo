                {
                    "name": "05 - Verify vote in votes list with linked image",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const votes = pm.response.json();",
                                    "const voteId = Number(pm.collectionVariables.get('vote_id'));",
                                    "const vote = votes.find((item) => Number(item.id) === voteId);",
                                    "",
                                    "pm.test('Created vote returns linked image object', function () {",
                                    "    pm.expect(votes).to.be.an('array');",
                                    "    pm.expect(vote).to.be.an('object');",
                                    "    pm.expect(vote.image_id).to.eql(pm.collectionVariables.get('image_id'));",
                                    "    pm.expect(vote.sub_id).to.eql(pm.collectionVariables.get('sub_id'));",
                                    "    pm.expect(vote.image).to.be.an('object');",
                                    "    pm.expect(vote.image.id).to.eql(pm.collectionVariables.get('image_id'));",
                                    "    pm.expect(vote.image.url).to.eql(pm.collectionVariables.get('image_url'));",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
