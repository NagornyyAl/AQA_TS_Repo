                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "x-api-key",
                                "value": "{{cat_api_key}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"image_id\": \"{{image_id}}\",\n    \"sub_id\": \"{{sub_id}}\",\n    \"value\": 1\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "{{cat_base_url}}/votes"
                    },
                    "response": []
