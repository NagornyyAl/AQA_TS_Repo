        {
            "name": "Petstore Store Order Smoke Scenario",
            "description": "Executable Postman scenario for POST /v2/store/order. Consumer/provider contract verification is covered by Pact tests in the repository.",
            "item": [
                {
                    "name": "01 - Place store order",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": ["pm.collectionVariables.set('ship_date', new Date().toISOString());"]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const order = pm.response.json();",
                                    "",
                                    "pm.test('Order response matches request contract fields', function () {",
                                    "    pm.expect(order.id).to.eql(Number(pm.collectionVariables.get('order_id')));",
                                    "    pm.expect(order.petId).to.eql(Number(pm.collectionVariables.get('pet_id')));",
                                    "    pm.expect(order.quantity).to.eql(Number(pm.collectionVariables.get('quantity')));",
                                    "    pm.expect(order.status).to.eql(pm.collectionVariables.get('order_status'));",
                                    "    pm.expect(order.complete).to.eql(pm.collectionVariables.get('order_complete') === 'true');",
                                    "    pm.expect(order.shipDate).to.be.a('string').and.not.empty;",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"id\": {{order_id}},\n    \"petId\": {{pet_id}},\n    \"quantity\": {{quantity}},\n    \"shipDate\": \"{{ship_date}}\",\n    \"status\": \"{{order_status}}\",\n    \"complete\": {{order_complete}}\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": "{{petstore_base_url}}/store/order"
                    },
                    "response": []
                }
            ]
        }
    ],
